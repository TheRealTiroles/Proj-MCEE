clear classes; 
close all;
clc;

t_antigos = timerfind;
if ~isempty(t_antigos)
    stop(t_antigos);
    delete(t_antigos);
end


figura = figure('Name', 'Menu');
altura = 10;
largura = 5;
time = 0;

t = timer('ExecutionMode', 'fixedRate', 'Period',...
                1, 'TimerFcn', @(src, ~) timer_t(time));

disp(time);

if time == 2
    MeuTetris3D = Game(altura, largura, figura);
end

function timer_t(src, time)
time = time + 1;
disp
if time == 2
    stop(src);
end
end