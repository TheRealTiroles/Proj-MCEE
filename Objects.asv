classdef Objects < handle
    properties
        position_;
        color_;
    end

    methods(Abstract)
        function this = Objects(initialCoords, color)
            this.position_ = initialCoords;
            this.color_ = color;
        end
    end
    methods(Sealed)
        function updatePosition(this, Coords)
            this.position_ = Coords;
        end
        function coords = getPosition(this)

        end
        

    end
end